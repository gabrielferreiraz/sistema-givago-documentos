# URL do webhook do N8N que processa o PDF
VITE_N8N_WEBHOOK_URL=https://reobote-n8n.to0i0r.easypanel.host/webhook/givago-pdf

# Token de segurança enviado no header Authorization: Bearer TOKEN
VITE_N8N_WEBHOOK_TOKEN=givago2024

# Tempo máximo de espera pela resposta do servidor (em ms). Padrão: 90000 (90s)
# Aumente se o Gotenberg estiver lento no cold start
VITE_PDF_TIMEOUT_MS=90000
